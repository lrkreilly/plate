# Copy to .env.local and fill in. .env.local is gitignored — never commit it.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App origin used to build magic-link redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (Supabase SMTP uses this; also future notification emails)
RESEND_API_KEY=

# Web Push (Sprint 5) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Vercel Cron auth (Sprint 3/5) — any long random string
CRON_SECRET=
